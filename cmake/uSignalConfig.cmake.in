#.rst:
# FinduSignal
# ------------
# 
# Finds the uSignal library and include directory.
#
# Imported targets
# ^^^^^^^^^^^^^^^^
#
# ``uSignal_FOUND``
#   True indicates uSignal was found.
# ``uSignal_VERSION_STRING``
#   The version found.
# ``uSignal::uSignal``
#   The uSignal library, if found. 
include(CMakeFindDependencyMacro)

find_dependency(MKL)
find_dependency(IPP)
find_dependency(TBB)

#@PACKAGE_INIT@

if (NOT TARGET uSignal::@PROJECT_NAME@)
   include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
endif()
#if(NOT TARGET uSignal::@PROJECT_NAME@)
#include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
#endif()
